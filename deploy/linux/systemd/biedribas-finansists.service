[Unit]
Description=Biedribas Finansists Flask app
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/biedribas-finansists
EnvironmentFile=/etc/biedribas-finansists.env
ExecStart=/opt/biedribas-finansists/.venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
